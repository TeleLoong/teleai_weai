{% assign items = include.items | default: empty %}

{% if items.size > 0 %}
  <div class="equipment-gallery row">
    {% for item in items %}
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="equipment-gallery-item">
          {%
            include figure.liquid
            loading="lazy"
            path=item.src
            alt=item.alt
            class="equipment-gallery-image"
            zoomable=true
            cache_bust=true
          %}
          {% if item.caption and item.caption != '' %}
            <div class="equipment-caption">{{ item.caption }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
