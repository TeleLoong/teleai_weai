---
layout: page
---
{% assign equipment = page.equipment | default: empty %}
{% assign lab = equipment.lab | default: empty %}
{% assign workspace = equipment.workspace | default: empty %}

<div class="equipment-page">
  {% if equipment.intro %}
    <p>{{ equipment.intro }}</p>
  {% endif %}

  <h2>{{ lab.title | default: '实验室照片' }}</h2>
  {% if lab.description %}
    <p class="text-muted">{{ lab.description }}</p>
  {% endif %}
  {% include equipment/gallery.liquid items=lab.items %}

  <h2>{{ workspace.title | default: '工作环境照片' }}</h2>
  {% if workspace.description %}
    <p class="text-muted">{{ workspace.description }}</p>
  {% endif %}
  {% include equipment/gallery.liquid items=workspace.items %}

  {% if content and content != blank %}
    {{ content }}
  {% endif %}
</div>
