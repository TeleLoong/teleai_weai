---
layout: page
---
{% assign team = page.team | default: empty %}
{% assign fixed_grid_group_ids = 'teachers|phd|ms' | split: '|' %}
{% assign text_only_group_ids = 'phd|ms' | split: '|' %}
{% assign has_current_members = false %}
{% if team.groups %}
  {% for group in team.groups %}
    {% assign group_members = group.members | default: empty %}
    {% if group_members.size > 0 %}
      {% assign has_current_members = true %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign has_alumni = false %}
{% if team.alumni_groups %}
  {% for group in team.alumni_groups %}
    {% assign group_members = group.members | default: empty %}
    {% if group_members.size > 0 %}
      {% assign has_alumni = true %}
    {% endif %}
  {% endfor %}
{% endif %}

<div class="team-page">
  {% if team.lead %}
    <a class="anchor" id="lead"></a>
    <div class="team-bar team-bar--top" aria-hidden="true">
      <div class="container">
        <div class="team-bar-title">负责人</div>
      </div>
    </div>

    <section class="team-section team-lead" aria-label="Team lead">
      <div class="team-content container">
        {% include team/member_card.liquid member=team.lead variant="lead" %}
      </div>
    </section>
  {% endif %}

  {% if has_current_members %}
    <a class="anchor" id="members"></a>
    <div class="team-bar team-bar--members" aria-hidden="true">
      <div class="container">
        <div class="team-bar-title">团队成员</div>
      </div>
    </div>

    <section class="team-section team-members" aria-label="Current members">
      <div class="team-content container">
        {% for group in team.groups %}
          {% assign group_members = group.members | default: empty %}
          {% if fixed_grid_group_ids contains group.id %}
            {% assign remainder = group_members.size | modulo: 4 %}
            {% assign missing_slots = 0 %}
            {% if remainder != 0 %}
              {% assign missing_slots = 4 | minus: remainder %}
            {% endif %}
            <div class="team-group team-group--fixed-three team-group--{{ group.id }}">
              <h3 class="team-group-title">{{ group.title }}</h3>
              <div class="team-grid-fixed-three">
                {% for member in group_members %}
                  <div class="team-grid-fixed-three__item">
                    {% if text_only_group_ids contains group.id %}
                      {% include team/member_card.liquid member=member variant="student" %}
                    {% else %}
                      {% include team/member_card.liquid member=member %}
                    {% endif %}
                  </div>
                {% endfor %}

                {% if missing_slots > 0 %}
                  {% for _slot in (1..missing_slots) %}
                    <div class="team-grid-fixed-three__item team-grid-fixed-three__item--placeholder" aria-hidden="true"></div>
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% elsif group_members.size > 0 %}
            <div class="team-group">
              <h3 class="team-group-title">{{ group.title }}</h3>
              <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3">
                {% for member in group_members %}
                  <div class="col mb-4">
                    {% if text_only_group_ids contains group.id %}
                      {% include team/member_card.liquid member=member variant="student" %}
                    {% else %}
                      {% include team/member_card.liquid member=member %}
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if has_alumni %}
    <a class="anchor" id="alumni"></a>
    <div class="team-bar" aria-hidden="true">
      <div class="container">
        <div class="team-bar-title">校友</div>
      </div>
    </div>

    <section class="team-section team-alumni" aria-label="Alumni">
      <div class="team-content container">
        {% include team/alumni_list.liquid alumni_groups=team.alumni_groups %}
      </div>
    </section>
  {% endif %}

  {% if content and content != blank %}
    <section class="team-section team-section--notes">
      <div class="team-content container">
        {{ content }}
      </div>
    </section>
  {% endif %}
</div>
