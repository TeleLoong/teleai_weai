---
layout: default
---

<div class="home-page">
  {% include home/top_banner.liquid %}

  {% assign home = page.home %}
  {% assign hero = home.hero %}
  {% assign hero_actions = home.hero_actions %}
  {% assign research = home.research %}
  {% assign research_cards = research.cards %}
  {% assign team = home.team %}
  {% assign team_members = team.members %}
  {% assign equipment = home.equipment %}
  {% assign equipment_items = equipment.items %}
  {% assign cta = home.cta %}

  {% assign hero_title = hero.title | default: site.title | default: 'Your Lab Name' %}
  {% assign hero_tagline = hero.tagline %}
  {% assign hero_intro = hero.intro %}

  <section class="home-hero-simple">
    <div class="container">
      <div class="home-hero-grid">
        <div class="home-hero-copy">
          <h1 class="home-hero-title">{{ hero_title | newline_to_br }}</h1>
          {% if hero_tagline %}
            <p class="home-hero-tagline">{{ hero_tagline }}</p>
          {% endif %}
          {% if hero_intro %}
            <p class="home-hero-intro">{{ hero_intro }}</p>
          {% endif %}
          {% if hero_actions and hero_actions.size > 0 %}
            <div class="home-hero-actions">
              {% for action in hero_actions %}
                {% if action.url %}
                  <a class="btn {{ action.style | default: 'btn-outline-primary' }}" href="{{ action.url | relative_url }}">
                    {{ action.text | default: '了解更多' }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {% if hero and hero.image %}
          <div class="home-hero-media">
            {%
              include figure.liquid
              loading="eager"
              path=hero.image
              sizes="(min-width: 992px) 420px, 92vw"
              alt=hero.image_alt
              class="home-hero-image"
              cache_bust=true
            %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  <section class="home-section home-highlights">
    <div class="container">
      <div class="home-highlights-grid">
        <div class="home-highlight-box" aria-hidden="true"></div>
        <div class="home-highlight-box" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <section class="home-section home-section--divider">
    <div class="container">
      <div class="home-section-header">
        <h2>{{ research.title | default: '研究方向' }}</h2>
        {% if research.more_url %}
          <a class="home-section-link" href="{{ research.more_url | relative_url }}">
            {{ research.more_text | default: '查看详情' }}
          </a>
        {% endif %}
      </div>

      <div class="row">
        {% for card in research_cards limit: 2 %}
          <div class="col-12 col-lg-6{% unless forloop.last %} mb-4 mb-lg-0{% endunless %}">
            <div class="home-card">
              {% if card.title %}
                <h3 class="home-card-title">{{ card.title }}</h3>
              {% endif %}
              {% if card.lead %}
                <p class="home-card-lead">{{ card.lead }}</p>
              {% endif %}
              {% if card.bullets and card.bullets.size > 0 %}
                <ul class="home-card-list">
                  {% for bullet in card.bullets %}
                    <li>{{ bullet }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
              {% if card.link_url %}
                <a class="home-card-more" href="{{ card.link_url | relative_url }}">
                  {{ card.link_text | default: '了解更多 →' }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% assign team_url = team.more_url | default: '/team/' %}

  <section class="home-section home-section--divider">
    <div class="container">
      <div class="home-section-header">
        <h2>{{ team.title | default: '团队' }}</h2>
        {% if team_url %}
          <a class="home-section-link" href="{{ team_url | relative_url }}">
            {{ team.more_text | default: '查看全部' }}
          </a>
        {% endif %}
      </div>

      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4">
        {% for member in team_members limit: 4 %}
          <div class="col mb-4">
            {% assign member_url = member.url | default: team_url %}
            <a class="home-team-card-link" href="{{ member_url | relative_url }}">
              <div class="home-team-card">
                <div class="home-team-image">
                  {% if member.image %}
                    {%
                      include figure.liquid
                      loading="lazy"
                      path=member.image
                      sizes="220px"
                      alt=member.image_alt
                      class="home-team-img"
                      cache_bust=true
                    %}
                  {% endif %}
                </div>
                <div class="home-team-meta">
                  <div class="home-team-name">{{ member.name }}</div>
                  <div class="home-team-role">{{ member.role }}</div>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% assign equipment_url = equipment.more_url | default: '/equipment/' %}
  <section class="home-section home-section--divider">
    <div class="container">
      <div class="home-section-header">
        <h2>{{ equipment.title | default: '设备' }}</h2>
        {% if equipment_url %}
          <a class="home-section-link" href="{{ equipment_url | relative_url }}">
            {{ equipment.more_text | default: '查看全部' }}
          </a>
        {% endif %}
      </div>

      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3">
        {% for item in equipment_items limit: 3 %}
          {% assign item_url = item.url | default: equipment_url %}
          <div class="col mb-4">
            <a class="home-photo-link" href="{{ item_url | relative_url }}">
              <div class="home-photo">
                {% if item.image %}
                  {%
                    include figure.liquid
                    loading="lazy"
                    path=item.image
                    sizes="(min-width: 992px) 300px, 92vw"
                    alt=item.image_alt
                    class="home-photo-img"
                    cache_bust=true
                  %}
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="home-section home-cta">
    <div class="container">
      <div class="home-cta-card">
        <div class="home-cta-copy">
          <h2 class="home-cta-title">{{ cta.title | default: '加入我们' }}</h2>
          {% if cta.text %}
            <p class="home-cta-text">{{ cta.text }}</p>
          {% endif %}
        </div>
        {% if cta.actions and cta.actions.size > 0 %}
          <div class="home-cta-actions">
            {% for action in cta.actions %}
              {% if action.url %}
                <a class="btn {{ action.style | default: 'btn-outline-primary' }}" href="{{ action.url | relative_url }}">
                  {{ action.text | default: '了解更多' }}
                </a>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  {% if content and content != blank %}
    <section class="home-section home-section--divider">
      <div class="container">
        <div class="home-markdown-content">{{ content }}</div>
      </div>
    </section>
  {% endif %}
</div>
