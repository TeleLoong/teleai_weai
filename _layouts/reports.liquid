---
layout: default
---
{% assign reports = page.reports | default: empty %}
{% assign show_download_link = reports.show_download_link | default: true %}
{% assign report_player_build = 'reports-20260317-2' %}
{% assign videos_section = reports.videos | default: empty %}
{% assign news_section = reports.news | default: empty %}
{% assign report_videos = videos_section.items | default: empty %}
{% assign report_news = news_section.items | default: empty %}

<div class="post reports-page">
  {% unless page.hide_page_header %}
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">{{ page.description }}</p>
    </header>
  {% endunless %}

  <article>
    <div class="reports-content" data-report-template-build="{{ report_player_build }}">
      {% if reports.intro %}
        <div class="reports-intro">
          {{ reports.intro | markdownify }}
        </div>
      {% endif %}

      {% if content and content != blank %}
        <div class="reports-body-content">
          {{ content }}
        </div>
      {% endif %}

      <section class="reports-section reports-section--videos" aria-labelledby="reports-videos-title">
        <div class="reports-section-heading">
          <h2 class="reports-section-title" id="reports-videos-title">{{ videos_section.title | default: '视频报道' }}</h2>
          <p class="reports-section-description">
            {{ videos_section.description | default: '按时间倒序展示团队公开播出的电视报道、采访和纪录片内容。' }}
          </p>
        </div>

        {% if report_videos and report_videos.size > 0 %}
          <div class="reports-timeline" aria-label="{{ videos_section.aria_label | default: '视频报道时间轴' }}">
            {% for video in report_videos %}
              {% assign title = video.title | default: '未命名视频报道' | to_s | strip %}
              {% assign date_label = video.date | default: '未标注日期' | to_s | strip %}
              {% assign description = video.description | to_s | strip %}
              {% assign playback_ref = video.playback | default: video.mp4 | to_s | strip %}
              {% assign original_ref = video.original | default: playback_ref | to_s | strip %}
              {% assign poster_ref = video.poster | to_s | strip %}
              {% assign report_id = 'report-video-' | append: forloop.index0 %}
              {% assign playback_url = playback_ref %}
              {% assign original_url = original_ref %}
              {% assign original_link_url = original_ref %}
              {% assign poster_url = poster_ref %}

              {% if playback_ref == '' %}
                {% continue %}
              {% endif %}

              {% unless playback_ref contains '://' %}
                {% assign playback_busted_url = playback_ref | bust_file_cache | relative_url %}
                {% assign playback_busted_parts = playback_busted_url | split: '?' %}
                {% assign playback_url = playback_busted_parts[0] | uri_escape | replace: '+', '%2B' | replace: '(', '%28' | replace: ')', '%29' %}
                {% if playback_busted_parts.size > 1 %}
                  {% assign playback_url = playback_url | append: '?' | append: playback_busted_parts[1] %}
                {% endif %}
              {% endunless %}

              {% unless original_ref contains '://' %}
                {% assign original_busted_url = original_ref | bust_file_cache | relative_url %}
                {% assign original_busted_parts = original_busted_url | split: '?' %}
                {% assign original_url = original_busted_parts[0] | uri_escape | replace: '+', '%2B' | replace: '(', '%28' | replace: ')', '%29' %}
                {% if original_busted_parts.size > 1 %}
                  {% assign original_url = original_url | append: '?' | append: original_busted_parts[1] %}
                {% endif %}
                {% assign original_link_url = original_ref
                  | relative_url
                  | uri_escape
                  | replace: '+', '%2B'
                  | replace: '(', '%28'
                  | replace: ')', '%29'
                %}
              {% endunless %}

              {% if poster_ref != blank %}
                {% unless poster_ref contains '://' %}
                  {% assign poster_busted_url = poster_ref | bust_file_cache | relative_url %}
                  {% assign poster_busted_parts = poster_busted_url | split: '?' %}
                  {% assign poster_url = poster_busted_parts[0] | uri_escape | replace: '+', '%2B' | replace: '(', '%28' | replace: ')', '%29' %}
                  {% if poster_busted_parts.size > 1 %}
                    {% assign poster_url = poster_url | append: '?' | append: poster_busted_parts[1] %}
                  {% endif %}
                {% endunless %}
              {% endif %}

              <article class="report-item">
                <div class="report-date">
                  <span class="report-date-chip">{{ date_label }}</span>
                </div>

                <div class="report-card">
                  <div class="report-cover">
                    <video
                      class="report-media report-media--video"
                      preload="metadata"
                      playsinline
                      data-report-video
                      data-report-id="{{ report_id }}"
                      data-report-template-build="{{ report_player_build }}"
                      data-report-has-cache-bust="{% if playback_ref contains '://' %}false{% else %}true{% endif %}"
                      data-original-src="{{ original_url }}"
                      data-playback-src="{{ playback_url }}"
                      {% if poster_ref != blank %}
                        poster="{{ poster_url }}"
                      {% endif %}
                    >
                      <source src="{{ playback_url }}" type="video/mp4">
                      您的浏览器暂不支持视频播放，请使用下方链接打开原文件。
                    </video>
                    <div class="report-video-status" data-report-video-status aria-live="polite"></div>
                    <div class="report-player-controls" data-report-player-controls>
                      <button
                        type="button"
                        class="report-player-toggle"
                        data-report-player-toggle
                        aria-label="播放视频"
                      >
                        播放
                      </button>
                      <div
                        class="report-player-progress"
                        data-report-progress
                        role="slider"
                        tabindex="0"
                        aria-label="视频进度"
                        aria-valuemin="0"
                        aria-valuemax="0"
                        aria-valuenow="0"
                      >
                        <div class="report-player-progress__buffered" data-report-buffered></div>
                        <div class="report-player-progress__played" data-report-played></div>
                        <div class="report-player-progress__thumb" data-report-thumb></div>
                      </div>
                      <div class="report-player-time" aria-live="off">
                        <span data-report-current-time>0:00</span>
                        <span>/</span>
                        <span data-report-duration>0:00</span>
                      </div>
                    </div>
                  </div>

                  <div class="report-body">
                    <h3 class="report-title">{{ title }}</h3>

                    <div class="report-meta">
                      <span class="report-tag">视频报道</span>
                    </div>

                    {% if description != '' %}
                      <p class="report-summary">{{ description }}</p>
                    {% endif %}

                    {% if show_download_link %}
                      <a class="report-link" href="{{ original_link_url }}" target="_blank" rel="noopener noreferrer">打开原文件</a>
                    {% endif %}
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <div class="reports-empty">{{ videos_section.empty_text | default: '暂无视频报道，后续将在这里持续更新。' }}</div>
        {% endif %}
      </section>

      <section class="reports-section reports-section--news" aria-labelledby="reports-news-title">
        <div class="reports-section-heading">
          <h2 class="reports-section-title" id="reports-news-title">{{ news_section.title | default: '新闻报道' }}</h2>
          <p class="reports-section-description">
            {{ news_section.description | default: '媒体转发与新闻图文统一收纳在这里，默认摘要展示，点击卡片可全屏查看完整内容。' }}
          </p>
        </div>

        {% if report_news and report_news.size > 0 %}
          <div class="reports-news-grid" aria-label="{{ news_section.aria_label | default: '新闻报道卡片列表' }}">
            {% for item in report_news %}
              {% assign title = item.title | default: '未命名新闻报道' | to_s | strip %}
              {% assign date_label = item.date | default: '未标注日期' | to_s | strip %}
              {% assign summary = item.summary | to_s | strip %}
              {% assign image_ref = item.image | to_s | strip %}
              {% assign link_ref = item.link | default: image_ref | to_s | strip %}
              {% assign preview_url = image_ref %}
              {% assign original_link_url = link_ref %}
              {% assign card_title = title %}
              {% assign news_toggle_id = 'report-news-toggle-' | append: forloop.index0 %}

              {% if image_ref == '' %}
                {% continue %}
              {% endif %}

              {% if date_label != '未标注日期' %}
                {% assign card_date = date_label | replace: '-', '.' %}
                {% assign card_title = card_date | append: ' ' | append: title %}
              {% endif %}

              {% unless image_ref contains '://' %}
                {% assign preview_url = image_ref | relative_url | uri_escape | replace: '+', '%2B' | replace: '(', '%28' | replace: ')', '%29' %}
              {% endunless %}

              {% unless link_ref contains '://' %}
                {% assign original_link_url = link_ref
                  | relative_url
                  | uri_escape
                  | replace: '+', '%2B'
                  | replace: '(', '%28'
                  | replace: ')', '%29'
                %}
              {% endunless %}

              <article class="report-news-card" data-report-news-card>
                <button
                  type="button"
                  class="report-news-toggle"
                  id="{{ news_toggle_id }}"
                  data-report-news-toggle
                  aria-expanded="false"
                  data-report-news-title="{{ title | escape }}"
                  data-report-news-date="{{ date_label | escape }}"
                  data-report-news-summary="{{ summary | escape }}"
                  data-report-news-image="{{ preview_url }}"
                  data-report-news-link="{{ original_link_url }}"
                >
                  <span class="report-news-thumb-wrap">
                    <img class="report-news-thumb" src="{{ preview_url }}" alt="{{ title }}" loading="lazy">
                  </span>
                  <span class="report-news-meta">
                    <span class="report-tag report-tag--news">新闻报道</span>
                    <span class="report-news-title">{{ card_title }}</span>
                    {% if summary != '' %}
                      <span class="report-news-summary">{{ summary }}</span>
                    {% endif %}
                  </span>
                </button>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <div class="reports-empty">{{ news_section.empty_text | default: '暂无新闻报道，后续将在这里持续更新。' }}</div>
        {% endif %}
      </section>

      <div
        class="reports-news-modal"
        data-report-news-modal
        aria-hidden="true"
        role="dialog"
        aria-modal="true"
        aria-labelledby="report-news-modal-title"
      >
        <div class="reports-news-modal__backdrop" data-report-news-close></div>
        <div class="reports-news-modal__dialog" role="document">
          <button type="button" class="reports-news-modal__close" data-report-news-close aria-label="关闭新闻预览">×</button>
          <div class="reports-news-modal__content">
            <div class="reports-news-modal__media">
              <img class="reports-news-modal__image" data-report-news-modal-image src="" alt="">
            </div>
            <div class="reports-news-modal__body">
              <span class="report-tag report-tag--news">新闻报道</span>
              <h3 class="reports-news-modal__title" id="report-news-modal-title" data-report-news-modal-title></h3>
              <p class="reports-news-modal__date" data-report-news-modal-date hidden></p>
              <p class="reports-news-modal__summary" data-report-news-modal-summary hidden></p>
              {% if show_download_link %}
                <a class="report-link reports-news-modal__link" data-report-news-modal-link href="" target="_blank" rel="noopener noreferrer"
                  >查看完整图片</a
                >
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</div>
